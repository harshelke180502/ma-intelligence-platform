# ── Database ────────────────────────────────────────────────────────────────
# asyncpg driver prefix is required for SQLAlchemy async engine
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ma_thesis

# ── External API keys ────────────────────────────────────────────────────────
# Google Places API — used by GooglePlacesCollector
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Anthropic Claude — used by classifier for ambiguous service descriptions
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Application ──────────────────────────────────────────────────────────────
DEBUG=false